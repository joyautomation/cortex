{
  "name": "@joyautomation/cortex",
  "version": "0.0.1",
  "description": "Shared Svelte SCADA component library for the Kraken stack — charts, trees, and process control visualization",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./charts": {
      "types": "./dist/components/charts/index.d.ts",
      "svelte": "./dist/components/charts/index.js",
      "default": "./dist/components/charts/index.js"
    },
    "./charts/types": {
      "types": "./dist/components/charts/types.d.ts",
      "default": "./dist/components/charts/types.js"
    },
    "./charts/utils": {
      "types": "./dist/components/charts/utils.d.ts",
      "default": "./dist/components/charts/utils.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "peerDependencies": {
    "svelte": "^5.0.0",
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^4.0.0",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "publint": "^0.3.0",
    "sass": "^1.77.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joyautomation/cortex.git"
  }
}
